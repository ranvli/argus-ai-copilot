{
  "Application": {
    "Name": "Argus AI Copilot",
    "Version": "0.1.0",
    "Environment": "Production"
  },

  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.Hosting.Lifetime": "Information",
      "Argus": "Information"
    }
  },

  "Providers": {
    "AI": {
      "Name": "",
      "Endpoint": "",
      "ModelId": ""
    },
    "Speech": {
      "Name": "",
      "Region": ""
    }
  },

  "Routing": {
    "Mode": "Automatic",
    "WorkflowOverrides": {
    }
  },

  "Storage": {
    "Mode": "Default",
    "MinFreeSpaceMb": 512,
    "MinArtifactFreeSpaceMb": 2048,
    "DataRootOverride": null,
    "CacheRootOverride": null,
    "ArtifactRootOverride": null
  },

  "ArgusAI": {
    "Profiles": [
      {
        "Name": "OllamaDefault",
        "Provider": "Ollama",
        "ModelId": "llama3",
        "Endpoint": "http://localhost:11434",
        "ApiKeySettingName": "",
        "TimeoutSeconds": 60,
        "Enabled": true
      },
      {
        "Name": "OpenAIDefault",
        "Provider": "OpenAI",
        "ModelId": "gpt-4o",
        "Endpoint": "https://api.openai.com/",
        "ApiKeySettingName": "OPENAI_API_KEY",
        "TimeoutSeconds": 90,
        "Enabled": false
      },
      {
        "Name": "WhisperOpenAI",
        "Provider": "OpenAI",
        "ModelId": "whisper-1",
        "Endpoint": "https://api.openai.com/",
        "ApiKeySettingName": "OPENAI_API_KEY",
        "TimeoutSeconds": 120,
        "Enabled": false
      },
      {
        "Name": "WhisperLocal",
        "Provider": "Whisper",
        "ModelId": "whisper-1",
        "Endpoint": "http://localhost:8080/",
        "ApiKeySettingName": "",
        "TimeoutSeconds": 120,
        "Enabled": false
      },
      {
        "Name": "WhisperNetLocal",
        "Provider": "WhisperNet",
        "ModelId": "base",
        "Endpoint": "",
        "ApiKeySettingName": "",
        "TimeoutSeconds": 120,
        "Enabled": true
      }
    ],
    "Defaults": {
      "Chat":              "OllamaDefault",
      "Vision":            "OpenAIDefault",
      "Transcription":     "WhisperNetLocal",
      "Embeddings":        "OllamaDefault",
      "Tts":               "OpenAIDefault"
    },
    "WorkflowMappings": [
      {
        "Workflow": "SpeechTranscription",
        "CapabilityProfiles": {
          "Transcription": "WhisperNetLocal"
        }
      }
    ]
  }
}
