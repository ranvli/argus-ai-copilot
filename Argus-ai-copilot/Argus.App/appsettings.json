{
  "Application": {
    "Name": "Argus AI Copilot",
    "Version": "0.1.0",
    "Environment": "Production"
  },

  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.Hosting.Lifetime": "Information",
      "Argus": "Information"
    }
  },

  "Providers": {
    "AI": {
      "Name": "",
      "Endpoint": "",
      "ModelId": ""
    },
    "Speech": {
      "Name": "",
      "Region": ""
    }
  },

  "Routing": {
    "Mode": "Automatic",
    "WorkflowOverrides": {
    }
  },

  "ArgusAI": {
    "Profiles": [
      {
        "Name": "OllamaDefault",
        "Provider": "Ollama",
        "ModelId": "llama3",
        "Endpoint": "http://localhost:11434",
        "ApiKeySettingName": "",
        "TimeoutSeconds": 60,
        "Enabled": true
      },
      {
        "Name": "OpenAIDefault",
        "Provider": "OpenAI",
        "ModelId": "gpt-4o",
        "Endpoint": "https://api.openai.com/",
        "ApiKeySettingName": "OPENAI_API_KEY",
        "TimeoutSeconds": 90,
        "Enabled": false
      }
    ],
    "Defaults": {
      "Chat":          "OllamaDefault",
      "Vision":        "OpenAIDefault",
      "Transcription": "OpenAIDefault",
      "Embeddings":    "OllamaDefault",
      "Tts":           "OpenAIDefault"
    },
    "WorkflowMappings": []
  }
}
