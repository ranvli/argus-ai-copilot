<Window x:Class="Argus.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Argus.App"
        mc:Ignorable="d"
        Title="Argus AI Copilot" Height="1060" Width="820"
        MinWidth="680" MinHeight="520"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5">

    <Window.Resources>
        <!-- Status dot colours -->
        <SolidColorBrush x:Key="OkBrush"      Color="#2E7D32"/>
        <SolidColorBrush x:Key="WarnBrush"    Color="#F57C00"/>
        <SolidColorBrush x:Key="ErrorBrush"   Color="#C62828"/>
        <SolidColorBrush x:Key="InfoBrush"    Color="#1565C0"/>
        <SolidColorBrush x:Key="NeutralBrush" Color="#757575"/>

        <!-- Section header style -->
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#424242"/>
            <Setter Property="Margin"     Value="0,0,0,6"/>
        </Style>

        <!-- Card panel style -->
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background"      Value="White"/>
            <Setter Property="CornerRadius"    Value="6"/>
            <Setter Property="Padding"         Value="14,10"/>
            <Setter Property="Margin"          Value="0,0,0,10"/>
            <Setter Property="BorderBrush"     Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <!-- Status row label -->
        <Style x:Key="StatusLabel" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="12"/>
            <Setter Property="Foreground" Value="#616161"/>
            <Setter Property="Width"      Value="130"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- Status row value -->
        <Style x:Key="StatusValue" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="12"/>
            <Setter Property="Foreground" Value="#212121"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- title bar -->
            <RowDefinition Height="*"/>      <!-- content -->
            <RowDefinition Height="Auto"/>   <!-- footer -->
        </Grid.RowDefinitions>

        <!-- ── Title ─────────────────────────────────────────────────────── -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,14">
            <TextBlock Text="Argus AI Copilot"
                       FontSize="20" FontWeight="SemiBold"
                       Foreground="#212121" VerticalAlignment="Center"/>
            <TextBlock x:Name="DiagnosticsTimestamp"
                       Text="Checking…"
                       FontSize="11" Foreground="#9E9E9E"
                       VerticalAlignment="Center" Margin="12,2,0,0"/>
        </StackPanel>

        <!-- ── Scrollable content ────────────────────────────────────────── -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!-- ── Session status card ───────────────────────────────── -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="Session" Style="{StaticResource SectionHeader}"/>

                        <!-- Listening state -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <Ellipse x:Name="SessionStateDot" Width="10" Height="10"
                                     Fill="{StaticResource NeutralBrush}"
                                     Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="State" Style="{StaticResource StatusLabel}"/>
                            <TextBlock x:Name="SessionStateText" Text="Idle"
                                       FontWeight="SemiBold"
                                       Style="{StaticResource StatusValue}"/>
                        </StackPanel>

                        <!-- Session ID -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <TextBlock Width="18" Margin="0,0,8,0"/>
                            <TextBlock Text="Session ID" Style="{StaticResource StatusLabel}"/>
                            <TextBlock x:Name="SessionIdText" Text="—"
                                       FontSize="11" FontFamily="Consolas"
                                       Foreground="#757575" VerticalAlignment="Center"/>
                        </StackPanel>

                        <!-- Start time -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <TextBlock Width="18" Margin="0,0,8,0"/>
                            <TextBlock Text="Started" Style="{StaticResource StatusLabel}"/>
                            <TextBlock x:Name="SessionStartedText" Text="—" Style="{StaticResource StatusValue}"/>
                        </StackPanel>

                        <!-- Live elapsed duration -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <TextBlock Width="18" Margin="0,0,8,0"/>
                            <TextBlock Text="Duration" Style="{StaticResource StatusLabel}"/>
                            <TextBlock x:Name="SessionDurationText" Text="—"
                                       FontFamily="Consolas" FontSize="13"
                                       Foreground="#1565C0"
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                        <!-- Event count -->
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Width="18" Margin="0,0,8,0"/>
                            <TextBlock Text="Events captured" Style="{StaticResource StatusLabel}"/>
                            <TextBlock x:Name="SessionEventCountText" Text="0" Style="{StaticResource StatusValue}"/>
                        </StackPanel>

                        <!-- Controls -->
                        <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                            <Button x:Name="StartSessionButton"  Content="▶ Start Listening"
                                    Padding="10,4" Margin="0,0,8,0"
                                    Click="StartSessionButton_Click"/>
                            <Button x:Name="PauseSessionButton"  Content="⏸ Pause"
                                    Padding="10,4" Margin="0,0,8,0" IsEnabled="False"
                                    Click="PauseSessionButton_Click"/>
                            <Button x:Name="ResumeSessionButton" Content="▶ Resume"
                                    Padding="10,4" Margin="0,0,8,0" IsEnabled="False"
                                    Click="ResumeSessionButton_Click"/>
                            <Button x:Name="StopSessionButton"   Content="■ Stop"
                                    Padding="10,4" IsEnabled="False"
                                    Click="StopSessionButton_Click"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- ── Active window context card ────────────────────────── -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="Active Window Context" Style="{StaticResource SectionHeader}"/>

                        <!-- App / process name -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <TextBlock Text="Application" Style="{StaticResource StatusLabel}"/>
                            <TextBlock x:Name="ActiveAppText" Text="—"
                                       Style="{StaticResource StatusValue}"/>
                        </StackPanel>

                        <!-- Process ID -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <TextBlock Text="Process ID" Style="{StaticResource StatusLabel}"/>
                            <TextBlock x:Name="ActiveProcessIdText" Text="—"
                                       FontFamily="Consolas" FontSize="11"
                                       Foreground="#757575" VerticalAlignment="Center"/>
                        </StackPanel>

                        <!-- Window title -->
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Window title" Style="{StaticResource StatusLabel}"/>
                            <TextBlock x:Name="ActiveWindowTitleText" Text="—"
                                       Style="{StaticResource StatusValue}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- ── System status card ────────────────────────────────── -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="System Status" Style="{StaticResource SectionHeader}"/>

                        <!-- Storage -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <Ellipse x:Name="StorageDot" Width="10" Height="10"
                                     Fill="{StaticResource NeutralBrush}"
                                     Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Local Storage" Style="{StaticResource StatusLabel}"/>
                            <TextBlock x:Name="StorageStatus" Text="—" Style="{StaticResource StatusValue}"/>
                        </StackPanel>

                        <!-- Database -->
                        <StackPanel Orientation="Horizontal">
                            <Ellipse x:Name="DatabaseDot" Width="10" Height="10"
                                     Fill="{StaticResource NeutralBrush}"
                                     Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Database" Style="{StaticResource StatusLabel}"/>
                            <TextBlock x:Name="DatabaseStatus" Text="—" Style="{StaticResource StatusValue}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- ── Storage paths card ─────────────────────────────── -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="Storage Paths" Style="{StaticResource SectionHeader}"/>

                        <!-- Mode -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <Ellipse x:Name="StorageModeDot" Width="10" Height="10"
                                     Fill="{StaticResource NeutralBrush}"
                                     Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Mode" Style="{StaticResource StatusLabel}"/>
                            <TextBlock x:Name="StorageModeText" Text="—"
                                       FontWeight="SemiBold"
                                       Style="{StaticResource StatusValue}"/>
                        </StackPanel>

                        <!-- Data folder -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <TextBlock Width="18" Margin="0,0,8,0"/>
                            <TextBlock Text="Data / DB" Style="{StaticResource StatusLabel}"/>
                            <TextBlock x:Name="StorageDataPathText" Text="—"
                                       FontSize="11" FontFamily="Consolas"
                                       Foreground="#424242" VerticalAlignment="Center"
                                       TextWrapping="Wrap"/>
                        </StackPanel>

                        <!-- Cache folder -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <TextBlock Width="18" Margin="0,0,8,0"/>
                            <TextBlock Text="Cache" Style="{StaticResource StatusLabel}"/>
                            <TextBlock x:Name="StorageCachePathText" Text="—"
                                       FontSize="11" FontFamily="Consolas"
                                       Foreground="#424242" VerticalAlignment="Center"
                                       TextWrapping="Wrap"/>
                        </StackPanel>

                        <!-- Artifacts folder -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <TextBlock Width="18" Margin="0,0,8,0"/>
                            <TextBlock Text="Artifacts" Style="{StaticResource StatusLabel}"/>
                            <TextBlock x:Name="StorageArtifactPathText" Text="—"
                                       FontSize="11" FontFamily="Consolas"
                                       Foreground="#424242" VerticalAlignment="Center"
                                       TextWrapping="Wrap"/>
                        </StackPanel>

                        <!-- Database file -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <TextBlock Width="18" Margin="0,0,8,0"/>
                            <TextBlock Text="Database" Style="{StaticResource StatusLabel}"/>
                            <TextBlock x:Name="StorageDatabasePathText" Text="—"
                                       FontSize="11" FontFamily="Consolas"
                                       Foreground="#424242" VerticalAlignment="Center"
                                       TextWrapping="Wrap"/>
                        </StackPanel>

                        <!-- Selection reason -->
                        <Border x:Name="StorageReasonBanner"
                                Background="#F3F8FF" BorderBrush="#90CAF9" BorderThickness="1"
                                CornerRadius="4" Padding="10,5" Margin="0,8,0,0"
                                Visibility="Collapsed">
                            <TextBlock x:Name="StorageDataReasonText"
                                       FontSize="11" Foreground="#1565C0"
                                       TextWrapping="Wrap"/>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- ── Providers card ─────────────────────────────────────── -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="AI Providers" Style="{StaticResource SectionHeader}"/>

                        <!-- Ollama -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <Ellipse x:Name="OllamaDot" Width="10" Height="10"
                                     Fill="{StaticResource NeutralBrush}"
                                     Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Ollama (local)" Style="{StaticResource StatusLabel}"/>
                            <TextBlock x:Name="OllamaStatus" Text="—" Style="{StaticResource StatusValue}"/>
                        </StackPanel>

                        <!-- OpenAI -->
                        <StackPanel Orientation="Horizontal">
                            <Ellipse x:Name="OpenAiDot" Width="10" Height="10"
                                     Fill="{StaticResource NeutralBrush}"
                                     Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="OpenAI (cloud)" Style="{StaticResource StatusLabel}"/>
                            <TextBlock x:Name="OpenAiStatus" Text="—" Style="{StaticResource StatusValue}"/>
                        </StackPanel>

                        <!-- Ollama warning -->
                        <Border x:Name="OllamaWarningBanner"
                                Background="#FFF8E1" BorderBrush="#FFD54F" BorderThickness="1"
                                CornerRadius="4" Padding="10,6" Margin="0,10,0,0"
                                Visibility="Collapsed">
                            <TextBlock x:Name="OllamaWarningText"
                                       Text="⚠ Ollama is not running. Start Ollama to enable local AI."
                                       FontSize="11" Foreground="#E65100"
                                       TextWrapping="Wrap"/>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- ── Routing card ───────────────────────────────────────── -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="Model Routing" Style="{StaticResource SectionHeader}"/>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <TextBlock Text="Routing mode" Style="{StaticResource StatusLabel}"/>
                            <TextBlock x:Name="RoutingModeText" Text="—"
                                       FontWeight="SemiBold"
                                       Style="{StaticResource StatusValue}"/>
                        </StackPanel>

                        <!-- Per-workflow rows -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="80"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Header row -->
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Workflow"
                                       FontSize="10" FontWeight="SemiBold" Foreground="#9E9E9E"
                                       Margin="0,0,0,4"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="Effective model"
                                       FontSize="10" FontWeight="SemiBold" Foreground="#9E9E9E"
                                       Margin="0,0,0,4"/>
                            <TextBlock Grid.Row="0" Grid.Column="2" Text="Status"
                                       FontSize="10" FontWeight="SemiBold" Foreground="#9E9E9E"
                                       Margin="0,0,0,4"/>

                            <!-- RealtimeAssist -->
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Realtime Assist"
                                       Style="{StaticResource StatusLabel}" Margin="0,3"/>
                            <TextBlock x:Name="RealtimeAssistModel" Grid.Row="1" Grid.Column="1"
                                       Text="—" Style="{StaticResource StatusValue}" Margin="0,3"/>
                            <TextBlock x:Name="RealtimeAssistState" Grid.Row="1" Grid.Column="2"
                                       Text="—" FontSize="11" VerticalAlignment="Center" Margin="0,3"/>

                            <!-- MemoryQuery -->
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Memory Query"
                                       Style="{StaticResource StatusLabel}" Margin="0,3"/>
                            <TextBlock x:Name="MemoryQueryModel" Grid.Row="2" Grid.Column="1"
                                       Text="—" Style="{StaticResource StatusValue}" Margin="0,3"/>
                            <TextBlock x:Name="MemoryQueryState" Grid.Row="2" Grid.Column="2"
                                       Text="—" FontSize="11" VerticalAlignment="Center" Margin="0,3"/>

                            <!-- MeetingSummary -->
                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Meeting Summary"
                                       Style="{StaticResource StatusLabel}" Margin="0,3"/>
                            <TextBlock x:Name="MeetingSummaryModel" Grid.Row="3" Grid.Column="1"
                                       Text="—" Style="{StaticResource StatusValue}" Margin="0,3"/>
                            <TextBlock x:Name="MeetingSummaryState" Grid.Row="3" Grid.Column="2"
                                       Text="—" FontSize="11" VerticalAlignment="Center" Margin="0,3"/>

                            <!-- ScreenExplain -->
                            <TextBlock Grid.Row="4" Grid.Column="0" Text="Screen Explain"
                                       Style="{StaticResource StatusLabel}" Margin="0,3"/>
                            <TextBlock x:Name="ScreenExplainModel" Grid.Row="4" Grid.Column="1"
                                       Text="—" Style="{StaticResource StatusValue}" Margin="0,3"/>
                            <TextBlock x:Name="ScreenExplainState" Grid.Row="4" Grid.Column="2"
                                       Text="—" FontSize="11" VerticalAlignment="Center" Margin="0,3"/>
                        </Grid>

                        <!-- No providers warning -->
                        <Border x:Name="NoProvidersBanner"
                                Background="#FFEBEE" BorderBrush="#EF9A9A" BorderThickness="1"
                                CornerRadius="4" Padding="10,6" Margin="0,10,0,0"
                                Visibility="Collapsed">
                            <TextBlock Text="⚠ No AI providers are available. Configure Ollama or an OpenAI API key to enable AI features."
                                       FontSize="11" Foreground="#B71C1C"
                                       TextWrapping="Wrap"/>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- ── Audio Capture card ────────────────────────────────── -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="Audio Capture" Style="{StaticResource SectionHeader}"/>

                        <!-- ── Backend override controls ─────────────────── -->
                        <Border Background="#FFF8E1" BorderBrush="#FFD54F" BorderThickness="1"
                                CornerRadius="4" Padding="10,8" Margin="0,0,0,10">
                            <StackPanel>
                                <TextBlock Text="⚙ Backend Override"
                                           FontSize="11" FontWeight="SemiBold"
                                           Foreground="#E65100" Margin="0,0,0,6"/>

                                <!-- Mic backend selector -->
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                    <TextBlock Text="Mic backend"
                                               Style="{StaticResource StatusLabel}" FontSize="11"/>
                                    <ComboBox x:Name="MicBackendComboBox"
                                              Width="140" FontSize="11"
                                              SelectionChanged="MicBackendComboBox_SelectionChanged"/>
                                </StackPanel>

                                <!-- WaveIn device selector -->
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                    <TextBlock Text="WaveIn device"
                                               Style="{StaticResource StatusLabel}" FontSize="11"/>
                                    <ComboBox x:Name="WaveInDeviceComboBox"
                                              Width="260" FontSize="11"
                                              SelectionChanged="WaveInDeviceComboBox_SelectionChanged"/>
                                </StackPanel>

                                <TextBlock x:Name="BackendOverrideHintText"
                                           Text="Changes take effect on the next session start."
                                           FontSize="10" Foreground="#795548"
                                           FontStyle="Italic"/>
                            </StackPanel>
                        </Border>

                        <!-- Microphone status -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <Ellipse x:Name="MicDot" Width="10" Height="10"
                                     Fill="{StaticResource NeutralBrush}"
                                     Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Microphone" Style="{StaticResource StatusLabel}"/>
                            <TextBlock x:Name="MicStatusText" Text="Idle"
                                       Style="{StaticResource StatusValue}"/>
                        </StackPanel>

                        <!-- Microphone device name -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <TextBlock Width="18" Margin="0,0,8,0"/>
                            <TextBlock Text="Device" Style="{StaticResource StatusLabel}"/>
                            <TextBlock x:Name="MicDeviceText" Text="—"
                                       FontSize="11" FontFamily="Consolas"
                                       Foreground="#616161" VerticalAlignment="Center"
                                       TextWrapping="Wrap"/>
                        </StackPanel>

                        <!-- Active backend row (shown while capturing) -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Width="18" Margin="0,0,8,0"/>
                            <TextBlock Text="Active backend" Style="{StaticResource StatusLabel}"/>
                            <TextBlock x:Name="MicActiveBackendText" Text="—"
                                       FontSize="11" FontFamily="Consolas"
                                       FontWeight="SemiBold"
                                       Foreground="#1565C0" VerticalAlignment="Center"/>
                        </StackPanel>

                        <!-- Microphone live signal level -->
                        <StackPanel x:Name="MicLevelPanel"
                                    Orientation="Horizontal" Margin="0,0,0,4"
                                    Visibility="Collapsed">
                            <TextBlock Width="18" Margin="0,0,8,0"/>
                            <TextBlock Text="Level" Style="{StaticResource StatusLabel}"/>
                            <TextBlock x:Name="MicLevelText"
                                       FontSize="11" FontFamily="Consolas"
                                       Foreground="#2E7D32" VerticalAlignment="Center"/>
                        </StackPanel>

                        <!-- Microphone native vs converted RMS (debug) -->
                        <StackPanel x:Name="MicSignalDebugPanel"
                                    Orientation="Horizontal" Margin="0,0,0,8"
                                    Visibility="Collapsed">
                            <TextBlock Width="18" Margin="0,0,8,0"/>
                            <TextBlock Text="Signal" Style="{StaticResource StatusLabel}"/>
                            <TextBlock x:Name="MicSignalDebugText"
                                       FontSize="10" FontFamily="Consolas"
                                       Foreground="#757575" VerticalAlignment="Center"/>
                        </StackPanel>

                        <!-- System audio status -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <Ellipse x:Name="SystemAudioDot" Width="10" Height="10"
                                     Fill="{StaticResource NeutralBrush}"
                                     Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="System Audio" Style="{StaticResource StatusLabel}"/>
                            <TextBlock x:Name="SystemAudioStatusText" Text="Not available"
                                       Style="{StaticResource StatusValue}"/>
                        </StackPanel>

                        <!-- System audio device name -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Width="18" Margin="0,0,8,0"/>
                            <TextBlock Text="Device" Style="{StaticResource StatusLabel}"/>
                            <TextBlock x:Name="SystemAudioDeviceText" Text="—"
                                       FontSize="11" FontFamily="Consolas"
                                       Foreground="#616161" VerticalAlignment="Center"
                                       TextWrapping="Wrap"/>
                        </StackPanel>

                        <!-- Transcription status -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <Ellipse x:Name="TranscriptionDot" Width="10" Height="10"
                                     Fill="{StaticResource NeutralBrush}"
                                     Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Transcription" Style="{StaticResource StatusLabel}"/>
                            <TextBlock x:Name="TranscriptionStatusText" Text="Idle"
                                       Style="{StaticResource StatusValue}"/>
                        </StackPanel>

                        <!-- Transcription provider/model -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <TextBlock Width="18" Margin="0,0,8,0"/>
                            <TextBlock Text="Provider / Model" Style="{StaticResource StatusLabel}"/>
                            <TextBlock x:Name="TranscriptionProviderText" Text="—"
                                       FontSize="11" FontFamily="Consolas"
                                       Foreground="#616161" VerticalAlignment="Center"/>
                        </StackPanel>

                        <!-- Whisper model download state -->
                        <StackPanel x:Name="WhisperDownloadStatePanel"
                                    Orientation="Horizontal" Margin="0,0,0,4"
                                    Visibility="Collapsed">
                            <TextBlock Width="18" Margin="0,0,8,0"/>
                            <TextBlock Text="Model state" Style="{StaticResource StatusLabel}"/>
                            <TextBlock x:Name="WhisperDownloadStateText" Text="—"
                                       FontSize="11" FontFamily="Consolas"
                                       Foreground="#616161" VerticalAlignment="Center"/>
                        </StackPanel>

                        <!-- Whisper local model path -->
                        <StackPanel x:Name="WhisperModelPathPanel"
                                    Orientation="Horizontal" Margin="0,0,0,4"
                                    Visibility="Collapsed">
                            <TextBlock Width="18" Margin="0,0,8,0"/>
                            <TextBlock Text="Model path" Style="{StaticResource StatusLabel}"/>
                            <TextBlock x:Name="WhisperModelPathText" Text="—"
                                       FontSize="11" FontFamily="Consolas"
                                       Foreground="#616161" VerticalAlignment="Center"
                                       TextWrapping="Wrap" MaxWidth="340"/>
                        </StackPanel>

                        <!-- Queue length -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <TextBlock Width="18" Margin="0,0,8,0"/>
                            <TextBlock Text="Queue" Style="{StaticResource StatusLabel}"/>
                            <TextBlock x:Name="TranscriptionQueueText" Text="0 chunks"
                                       FontSize="11" FontFamily="Consolas"
                                       Foreground="#616161" VerticalAlignment="Center"/>
                        </StackPanel>

                        <!-- Last transcript time -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <TextBlock Width="18" Margin="0,0,8,0"/>
                            <TextBlock Text="Last transcript" Style="{StaticResource StatusLabel}"/>
                            <TextBlock x:Name="LastTranscriptTimeText" Text="—"
                                       FontSize="11" FontFamily="Consolas"
                                       Foreground="#616161" VerticalAlignment="Center"/>
                        </StackPanel>

                        <!-- Last transcription error (hidden when none) -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <TextBlock Width="18" Margin="0,0,8,0"/>
                            <TextBlock Text="Last error" Style="{StaticResource StatusLabel}"/>
                            <TextBlock x:Name="LastTranscriptionErrorText" Text="—"
                                       FontSize="11" Foreground="#C62828"
                                       VerticalAlignment="Center" TextWrapping="Wrap"/>
                        </StackPanel>

                        <!-- No transcription provider warning banner -->
                        <Border x:Name="TranscriptionNotConfiguredBanner"
                                Background="#FFEBEE" BorderBrush="#EF9A9A" BorderThickness="1"
                                CornerRadius="4" Padding="10,6" Margin="0,8,0,0"
                                Visibility="Collapsed">
                            <TextBlock x:Name="TranscriptionNotConfiguredText"
                                       FontSize="11" Foreground="#B71C1C"
                                       TextWrapping="Wrap"/>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- ── Argus Assistant card ──────────────────────────────────── -->
                <Border x:Name="AssistantCard"
                        Style="{StaticResource Card}"
                        Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Text="Argus Assistant"
                                   Style="{StaticResource SectionHeader}"
                                   Margin="0,0,0,8"/>

                        <!-- Wake phrase -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <TextBlock Width="18" Margin="0,0,8,0"/>
                            <TextBlock Text="Wake phrase" Style="{StaticResource StatusLabel}"/>
                            <TextBlock x:Name="AssistantWakePhraseText" Text="—"
                                       FontSize="11" FontFamily="Consolas"
                                       Foreground="#616161" VerticalAlignment="Center"/>
                        </StackPanel>

                        <!-- Intent -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <TextBlock Width="18" Margin="0,0,8,0"/>
                            <TextBlock Text="Intent" Style="{StaticResource StatusLabel}"/>
                            <TextBlock x:Name="AssistantIntentText" Text="—"
                                       FontSize="11" FontFamily="Consolas"
                                       Foreground="#616161" VerticalAlignment="Center"/>
                        </StackPanel>

                        <!-- Timestamp -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Width="18" Margin="0,0,8,0"/>
                            <TextBlock Text="At" Style="{StaticResource StatusLabel}"/>
                            <TextBlock x:Name="AssistantTimeText" Text="—"
                                       FontSize="11" FontFamily="Consolas"
                                       Foreground="#616161" VerticalAlignment="Center"/>
                        </StackPanel>

                        <!-- Suggestion -->
                        <Border Background="#F1F8E9" BorderBrush="#AED581" BorderThickness="1"
                                CornerRadius="4" Padding="10,8" Margin="0,0,0,0">
                            <TextBlock x:Name="AssistantSuggestionText"
                                       FontSize="12"
                                       Foreground="#212121"
                                       TextWrapping="Wrap"
                                       Text="—"/>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- ── Live Transcript card ───────────────────────────────── -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Text="Live Transcript"
                                       Style="{StaticResource SectionHeader}"
                                       Margin="0"/>
                            <TextBlock x:Name="TranscriptSegmentCountText"
                                       Text="(0 segments)"
                                       FontSize="11" Foreground="#9E9E9E"
                                       VerticalAlignment="Center" Margin="8,0,0,0"/>
                        </StackPanel>

                        <!-- Placeholder shown when no segments yet -->
                        <TextBlock x:Name="TranscriptPlaceholder"
                                   Text="Transcript will appear here once a session starts and audio is detected."
                                   FontSize="11" Foreground="#9E9E9E"
                                   TextWrapping="Wrap" FontStyle="Italic"
                                   Margin="0,0,0,4"/>

                        <!-- Scrollable segment list — max ~220px tall, shown once segments arrive -->
                        <Border x:Name="TranscriptListBorder"
                                BorderBrush="#E0E0E0" BorderThickness="1"
                                CornerRadius="4" Padding="8,6"
                                Background="#FAFAFA"
                                Visibility="Collapsed">
                            <ScrollViewer x:Name="TranscriptScrollViewer"
                                          MaxHeight="220"
                                          VerticalScrollBarVisibility="Auto">
                                <StackPanel x:Name="TranscriptItemsPanel"/>
                            </ScrollViewer>
                        </Border>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- ── Footer ────────────────────────────────────────────────────── -->
        <TextBlock Grid.Row="2"
                   x:Name="FooterText"
                   Text="Argus AI Copilot — minimises to tray."
                   FontSize="10" Foreground="#9E9E9E"
                   HorizontalAlignment="Right" Margin="0,8,0,0"/>
    </Grid>
</Window>
